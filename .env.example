# Copy this file to .env. Keep real keys and channel identifiers out of git.
# Empty provider values defer to config.json instead of overriding it.

# Text and image providers
TEXT_PROVIDER=
IMAGE_PROVIDER=
OLLAMA_BASE_URL=
HERMES_TEXT_PROVIDER=
HERMES_TEXT_MODEL=
SCRIPT_REVIEW_ENABLED=
SCRIPT_REVIEW_MODEL=

# Provider credentials. Hermes subprocesses inherit OPENAI_API_KEY when used.
GOOGLE_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# Optional Hermes image generation (the default queue remains under .mp/).
HERMES_CLI=hermes
HERMES_IMAGE_PROVIDER=openai-codex
HERMES_IMAGE_MODEL=gpt-5.5
HERMES_IMAGE_TIMEOUT_SECONDS=600
HERMES_ENABLE_CLI_IMAGE_GENERATION=0

# YouTube channel identity. Set ID before any public upload.
YOUTUBE_CHANNEL_SLUG=
YOUTUBE_CHANNEL_NAME=
YOUTUBE_CHANNEL_ID=
YOUTUBE_NOTIFY_SUBSCRIBERS=false

# Batch selection and upload safety gates.
NEWS_LIMIT=50
EXCLUDE_TERMS=
START_RANK=1
END_RANK=5
ALLOW_PUBLIC_UPLOAD=0
ALLOW_UNREVIEWED_UPLOADS=0
UPDATE_UPLOAD_HISTORY=0
UPDATE_ARCHIVE_STATUS=0

# Scheduled job defaults. Public visibility still requires ALLOW_PUBLIC_UPLOAD=1.
SHORTS_JOB_VISIBILITY=unlisted
SHORTS_JOB_DRY_RUN=0
SHORTS_JOB_TOPIC=

# Optional cross-posting
POST_BRIDGE_API_KEY=
